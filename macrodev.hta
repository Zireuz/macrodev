<html>
<head>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8">
<HTA:APPLICATION
    ID="MacroDevHTA"
    APPLICATIONNAME="MacroDev"
    SCROLL="no"
    SINGLEINSTANCE="yes"
    WINDOWSTATE="normal"
    MAXIMIZEBUTTON="no"
    MINIMIZEBUTTON="yes"
    CAPTION="yes"
    BORDER="dialog"
/>
<title>MacroDev</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body {
    height: 100%;
    overflow: hidden;
    background: #07101a;
    color: #dde6f0;
    font-family: 'Segoe UI', Tahoma, sans-serif;
    font-size: 16px;
}
#izq {
    position: absolute;
    left: 0; top: 0;
    overflow-y: scroll;
    padding: 1.4em 1.2em 2em 1.5em;
    background: #07101a;
    border-right: 1px solid #152030;
}
#der {
    position: absolute;
    top: 0;
    background: #050d16;
}
#der-inner {
    text-align: center;
    padding: 1.5em;
}
/* LOGO */
.logo {
    text-align: center;
    margin-bottom: 1.3em;
    padding-bottom: 1.1em;
    border-bottom: 1px solid #152030;
}
.logo-tag {
    display: inline-block;
    background: #071828;
    border: 1px solid #1a4060;
    border-radius: 2em;
    padding: 0.3em 1.1em;
    font-size: 0.68em;
    color: #38bdf8;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 0.75em;
}
.logo h1 { font-size: 2em; font-weight: 700; color: #fff; letter-spacing: -0.05em; line-height: 1.2; }
.logo h1 em { color: #38bdf8; font-style: normal; }
.logo p { color: #3d5a72; font-size: 0.72em; margin-top: 0.4em; font-family: 'Courier New', monospace; }
/* BLOQUES */
.bloque {
    background: #0a1828;
    border: 1px solid #152030;
    border-radius: 0.65em;
    padding: 1.1em;
    margin-bottom: 0.9em;
}
.bloque-titulo {
    font-size: 0.66em;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #2a7aaa;
    font-family: 'Courier New', monospace;
    margin-bottom: 1em;
    padding-bottom: 0.65em;
    border-bottom: 1px solid #152030;
}
/* ITEMS */
.item { display: table; width: 100%; margin-bottom: 0.85em; }
.item-icono {
    display: table-cell;
    width: 2.2em;
    vertical-align: top;
    padding-top: 0.1em;
    color: #2a7aaa;
    font-family: 'Courier New', monospace;
    font-size: 0.82em;
    font-weight: bold;
}
.item-body { display: table-cell; vertical-align: top; }
.item-body b { display: block; color: #edf4fa; font-size: 0.95em; margin-bottom: 0.3em; font-weight: 600; }
.item-body p { color: #4a6a82; font-size: 0.82em; line-height: 1.75; }
/* ARBOL */
.arbol {
    background: #040c14;
    border: 1px solid #152030;
    border-radius: 0.5em;
    padding: 0.75em 1em;
    font-family: 'Courier New', monospace;
    font-size: 0.8em;
    color: #4a6a82;
    line-height: 2;
    margin-top: 0.7em;
}
.arbol .az { color: #38bdf8; }
.arbol .vd { color: #22c55e; }
.arbol .dt { color: #1e3a4a; }
/* CODE */
code {
    background: #071828;
    border: 1px solid #1a3a52;
    border-radius: 0.3em;
    padding: 0.15em 0.45em;
    color: #38bdf8;
    font-family: 'Courier New', monospace;
    font-size: 0.78em;
}
/* PASOS */
.paso { display: table; width: 100%; margin-bottom: 0.9em; }
.paso-n { display: table-cell; width: 2.2em; vertical-align: top; padding-top: 0.15em; }
.circulo {
    width: 1.6em; height: 1.6em;
    background: #071828;
    border: 1px solid #1a4060;
    border-radius: 50%;
    text-align: center;
    line-height: 1.5em;
    font-size: 0.78em;
    font-weight: bold;
    color: #38bdf8;
    font-family: 'Courier New', monospace;
}
.paso-body { display: table-cell; vertical-align: top; padding-left: 0.4em; }
.paso-body b { display: block; color: #edf4fa; font-size: 0.95em; margin-bottom: 0.3em; font-weight: 600; }
.paso-body p { color: #4a6a82; font-size: 0.82em; line-height: 1.75; }
/* QR DERECHA */
.qr-label {
    font-size: 0.66em;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #2a7aaa;
    font-family: 'Courier New', monospace;
    margin-bottom: 1em;
}
.qr-marco {
    display: inline-block;
    background: #fff;
    padding: 0.75em;
    border-radius: 0.75em;
    margin-bottom: 0.9em;
    line-height: 0;
}
.qr-dir {
    background: #040c14;
    border: 1px solid #1a3a52;
    border-radius: 0.5em;
    padding: 0.6em 0.8em;
    font-family: 'Courier New', monospace;
    font-size: 0.75em;
    color: #38bdf8;
    text-align: center;
    margin-bottom: 0.9em;
    word-break: break-all;
}
.ext-badge {
    display: inline-block;
    padding: 0.45em 1.1em;
    border-radius: 2em;
    font-size: 0.78em;
    font-family: 'Courier New', monospace;
    background: #0a1828;
    border: 1px solid #1a3050;
    color: #3d5a72;
    margin-bottom: 1em;
}
.ext-badge.ok  { background: #041a0c; border-color: #16a34a; color: #22c55e; }
.ext-badge.err { background: #180808; border-color: #991b1b; color: #f87171; }
.qr-aviso { color: #2a4a5e; font-size: 0.75em; line-height: 1.8; }
.pie {
    margin-top: 1.2em;
    color: #0e2030;
    font-size: 0.68em;
    font-family: 'Courier New', monospace;
}
</style>
</head>
<body>

<div id="izq">
    <div class="logo">
        <div class="logo-tag">MacroDev v1.0</div>
        <h1>Control <em>Local</em><br>de Entornos</h1>
        <p>// Panel asincrono &middot; Node + React + Vite</p>
    </div>

    <div class="bloque">
        <div class="bloque-titulo">Como funciona MacroDev</div>
        <div class="item">
            <div class="item-icono">[D]</div>
            <div class="item-body">
                <b>Estructura de carpetas</b>
                <p>MacroDev debe estar en la carpeta raiz al mismo nivel que tus proyectos. Detecta automaticamente cualquier subcarpeta con <code>package.json</code>.</p>
            </div>
        </div>
        <div class="arbol">
            PORTAFOLIO\<br>
            &nbsp;&nbsp;&#9500;&#9472;&#9472; <span class="az">macroweb\</span>&nbsp;&nbsp;<span class="dt">&lt;-- MacroDev</span><br>
            &nbsp;&nbsp;&#9500;&#9472;&#9472; <span class="vd">proyecto-react\</span><br>
            &nbsp;&nbsp;&#9474;&nbsp;&nbsp;&nbsp;&#9492;&#9472;&#9472; package.json<br>
            &nbsp;&nbsp;&#9492;&#9472;&#9472; <span class="vd">otro-proyecto\</span><br>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#9500;&#9472;&#9472; frontend\<br>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#9474;&nbsp;&nbsp;&nbsp;&#9492;&#9472;&#9472; package.json<br>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#9492;&#9472;&#9472; backend\<br>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#9492;&#9472;&#9472; package.json
        </div>
        <div class="item" style="margin-top:0.75em">
            <div class="item-icono">[?]</div>
            <div class="item-body">
                <b>Deteccion automatica</b>
                <p>Lee los <code>scripts</code> de cada <code>package.json</code> y genera los botones del panel sin configuracion manual.</p>
            </div>
        </div>
        <div class="item">
            <div class="item-icono">[M]</div>
            <div class="item-body">
                <b>Acceso desde el movil</b>
                <p>Escanea el QR de la derecha con la camara. Ambos dispositivos deben estar en la misma red WiFi.</p>
            </div>
        </div>
    </div>

    <div class="bloque">
        <div class="bloque-titulo">Extension VS Code (requerida)</div>
        <div class="item" style="margin-bottom:0.9em">
            <div class="item-icono">[!]</div>
            <div class="item-body">
                <b>Para que sirve</b>
                <p>Sin la extension los botones de terminal no funcionan. Levanta un servidor interno en <code>:4001</code> que ejecuta las ordenes de MacroDev como terminales integradas en VS Code.</p>
            </div>
        </div>
        <div class="paso">
            <div class="paso-n"><div class="circulo">1</div></div>
            <div class="paso-body">
                <b>Instalar el archivo .vsix</b>
                <p><code>code --install-extension macrodev-terminal-1.0.0.vsix</code></p>
                <p style="margin-top:0.3em">O desde VS Code: <code>Ctrl+Shift+X</code> &rarr; <code>...</code> &rarr; <code>Install from VSIX</code></p>
            </div>
        </div>
        <div class="paso">
            <div class="paso-n"><div class="circulo">2</div></div>
            <div class="paso-body">
                <b>Reiniciar VS Code completamente</b>
                <p>Cierra con la X y vuelve a abrirlo. No uses Reload Window.</p>
            </div>
        </div>
        <div class="paso">
            <div class="paso-n"><div class="circulo">3</div></div>
            <div class="paso-body">
                <b>Verificar en barra inferior</b>
                <p>Deberia aparecer <code>MacroDev :4001</code> en la barra de estado de VS Code. El indicador aparece en el panel del QR a la derecha.</p>
            </div>
        </div>
    </div>
</div>

<div id="der">
    <div id="der-inner">
        <div class="qr-label">Acceso movil</div>
        <div class="qr-marco">
            <img id="qr-img" src="about:blank" width="200" height="200" alt="QR">
        </div>
        <div class="qr-dir" id="qr-dir">Obteniendo direccion...</div>
        <div class="ext-badge" id="ext-badge">Verificando extension...</div>
        <p class="qr-aviso">Apunta la camara al QR<br>para abrir el panel.<br><br>Misma red WiFi requerida.</p>
        <div class="pie">MacroDev &middot; localhost:4000</div>
    </div>
</div>

<script type="text/javascript">
    function ajustarLayout() {
        var sw = screen.width;
        var sh = screen.height;

        // Escalar fuente base segun resolucion — todo lo demas en em escalara con ella
        var escala = Math.max(1.0, Math.min(sw / 1280, 1.8));
        var fBase  = Math.round(16 * escala);
        document.body.style.fontSize = fBase + 'px';

        // Tamaño ventana: 78% pantalla
        var ww = Math.max(860,  Math.min(Math.round(sw * 0.78), 1500));
        var wh = Math.max(600,  Math.min(Math.round(sh * 0.84), 1050));
        window.resizeTo(ww, wh);
        window.moveTo(Math.round((sw - ww) / 2), Math.round((sh - wh) / 2));

        var cw = document.body.clientWidth  || ww;
        var ch = document.body.clientHeight || wh;

        // Columnas
        var izqW = Math.round(cw * 0.56);
        var derW = cw - izqW;

        var izq = document.getElementById('izq');
        izq.style.width  = izqW + 'px';
        izq.style.height = ch + 'px';

        var der = document.getElementById('der');
        der.style.width  = derW + 'px';
        der.style.height = ch + 'px';
        der.style.left   = izqW + 'px';

        // QR: proporcional al espacio disponible
        var qrSize = Math.min(Math.round(derW * 0.65), Math.round(ch * 0.34));
        qrSize = Math.max(160, qrSize);
        var img = document.getElementById('qr-img');
        img.width  = qrSize;
        img.height = qrSize;

        // Centrar verticalmente columna derecha
        var inner  = document.getElementById('der-inner');
        inner.style.paddingTop = fBase + 'px';
        var innerH = inner.offsetHeight;
        if (ch > innerH) {
            inner.style.paddingTop = Math.floor((ch - innerH) / 2) + 'px';
        }
    }

    function obtenerInfo() {
        var xhr = new XMLHttpRequest();
        xhr.open('GET', 'http://localhost:4000/api/info', true);
        xhr.onreadystatechange = function() {
            if (xhr.readyState === 4 && xhr.status === 200) {
                var data     = eval('(' + xhr.responseText + ')');
                var urlPanel = data.url + '/panel';
                document.getElementById('qr-dir').innerHTML = urlPanel;
                var t = new Date().getTime();
                document.getElementById('qr-img').src =
                    'http://localhost:4000/api/qr?url=' + encodeURIComponent(urlPanel) + '&t=' + t;
            } else if (xhr.readyState === 4) {
                document.getElementById('qr-dir').innerHTML = 'Error al conectar';
            }
        };
        xhr.send();
    }

    function checkExt() {
        var xhr = new XMLHttpRequest();
        xhr.open('GET', 'http://127.0.0.1:4001/ping', true);
        xhr.timeout = 2000;
        xhr.onreadystatechange = function() {
            if (xhr.readyState === 4) {
                var el = document.getElementById('ext-badge');
                if (xhr.status === 200) {
                    el.innerHTML = 'OK -- Extension activa en :4001';
                    el.className = 'ext-badge ok';
                } else {
                    el.innerHTML = 'X -- No detectada -- abre VS Code';
                    el.className = 'ext-badge err';
                }
            }
        };
        xhr.onerror = function() {
            var el = document.getElementById('ext-badge');
            el.innerHTML = 'X -- No detectada -- abre VS Code';
            el.className = 'ext-badge err';
        };
        xhr.send();
    }

    window.onload = function() {
        ajustarLayout();
        obtenerInfo();
        checkExt();
        setInterval(checkExt, 5000);
    };
</script>

<script language="VBScript">
    Sub window_onunload()
        Dim oShell
        Set oShell = CreateObject("WScript.Shell")
        oShell.Run "cmd.exe /c FOR /F ""tokens=5"" %P IN ('netstat -a -n -o ^| findstr :4000') DO taskkill /F /PID %P", 0, False
    End Sub
</script>

</body>
</html>
